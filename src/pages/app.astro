---
import '../styles/tailwind.css';
import PiTool from '../components/PiTool.tsx';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
			<link rel="stylesheet" href="/src/styles/tailwind.css" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Dimensional Analysis Tool</title>
	</head>
	<body>
		<main class="flex flex-col sm:grid sm:grid-cols-12 p-4 bg-gray-100 min-h-screen min-w-screen gap-2">
			<div class="hidden sm:grid sm:col-span-2 h-100% p-4 rounded-lg bg-slate-600 shadow-lg">
                <h1 class="text-4xl font-bold mb-4 text-center text-white">Dimensional Analysis Tool</h1>
            </div>
            <div class="col-span-10">
            <PiTool client:load />
            </div>
		</main>
	</body>
</html>
