		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Dimensional Analysis Tool</title>
	</head>
	<body>
		<main class="flex flex-col sm:grid sm:grid-cols-12 p-4 dark:bg-zinc-600 bg-gray-100 min-h-screen min-w-screen gap-2">
